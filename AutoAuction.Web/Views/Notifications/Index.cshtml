@model AutoAuction.Web.Models.NotificationsViewModel
@using AutoAuction.Domain.Enums

@{
    ViewData["Title"] = "Notificari";

    string ActiveClass(string filter) => Model.Filter == filter ? "is-active" : string.Empty;

    string BadgeClass(NotificationType type) => type switch
    {
        NotificationType.Outbid => "notification-type-badge--danger",
        NotificationType.AuctionWon => "notification-type-badge--success",
        NotificationType.AuctionLost => "notification-type-badge--muted",
        NotificationType.TransactionCreated => "notification-type-badge--info",
        NotificationType.NewBid => "notification-type-badge--primary",
        NotificationType.AuctionEnded => "notification-type-badge--dark",
        _ => "notification-type-badge--dark"
    };

    string TypeLabel(NotificationType type) => type switch
    {
        NotificationType.NewBid => "Bid nou",
        NotificationType.Outbid => "Depasit",
        NotificationType.AuctionWon => "Castigata",
        NotificationType.AuctionLost => "Pierduta",
        NotificationType.AuctionEnded => "Finalizata",
        NotificationType.TransactionCreated => "Tranzactie",
        _ => "Notificare"
    };
}

<section class="notifications-page">
    <div class="notifications-header">
        <div>
            <h1>Notificari</h1>
            <p>
                @if (Model.UnreadCount == 0)
                {
                    <span>Nu ai notificari necitite.</span>
                }
                else if (Model.UnreadCount == 1)
                {
                    <span>Ai o notificare necitita.</span>
                }
                else
                {
                    <span>Ai @Model.UnreadCount notificari necitite.</span>
                }
            </p>
        </div>

        <div class="notifications-actions">
            @if (Model.UnreadCount > 0)
            {
                <form asp-action="MarkAllRead" method="post">
                    <button class="btn btn-outline-secondary" type="submit">Marchează toate ca citite</button>
                </form>
            }
            @if (Model.TotalCount > Model.UnreadCount)
            {
                <form asp-action="DeleteRead" method="post">
                    <button class="btn btn-outline-danger" type="submit">Șterge citite</button>
                </form>
            }
        </div>
    </div>

    <nav class="notifications-tabs" aria-label="Filtre notificari">
        <a class="@ActiveClass("all")" asp-action="Index" asp-route-filter="all">
            Toate
            <span>@Model.TotalCount</span>
        </a>
        <a class="@ActiveClass("unread")" asp-action="Index" asp-route-filter="unread">
            Necitite
            <span>@Model.UnreadCount</span>
        </a>
        <a class="@ActiveClass("auctions")" asp-action="Index" asp-route-filter="auctions">
            Licitatii
            <span>@Model.AuctionCount</span>
        </a>
        <a class="@ActiveClass("transactions")" asp-action="Index" asp-route-filter="transactions">
            Tranzactii
            <span>@Model.TransactionCount</span>
        </a>
    </nav>

    @if (Model.Notifications.Count == 0)
    {
        <div class="alert alert-info">Nu exista notificari pentru filtrul selectat.</div>
    }
    else
    {
        <div class="notifications-list">
            @foreach (var notification in Model.Notifications)
            {
                <article class="notification-card @(notification.IsRead ? string.Empty : "is-unread")">
                    <div class="notification-card__main">
                        <div class="notification-card__badges">
                            <span class="notification-type-badge @BadgeClass(notification.Type)">@TypeLabel(notification.Type)</span>
                            @if (!notification.IsRead)
                            {
                                <span class="notification-read-badge">Necitita</span>
                            }
                        </div>
                        <h2>@notification.Title</h2>
                        <p>@notification.Message</p>
                    </div>
                    <div class="notification-card__side">
                        <time>@notification.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</time>
                        @if (!notification.IsRead)
                        {
                            <form asp-action="MarkRead" method="post">
                                <input type="hidden" name="id" value="@notification.Id" />
                                <button class="btn btn-sm btn-outline-primary" type="submit">Marcheaza citita</button>
                            </form>
                        }
                    </div>
                </article>
            }
        </div>
    }
</section>
