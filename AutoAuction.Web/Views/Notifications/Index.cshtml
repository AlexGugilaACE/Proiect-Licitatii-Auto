@model IReadOnlyList<AutoAuction.Domain.Entities.Notification>

@{
    ViewData["Title"] = "Notificari";
    var unreadCount = Model.Count(x => !x.IsRead);
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1">Notificari</h1>
        <div class="text-muted">
            @if (unreadCount == 0)
            {
                <span>Nu ai notificari necitite.</span>
            }
            else if (unreadCount == 1)
            {
                <span>Ai o notificare necitita.</span>
            }
            else
            {
                <span>Ai @unreadCount notificari necitite.</span>
            }
        </div>
    </div>

    @if (unreadCount > 0)
    {
        <form asp-action="MarkAllRead" method="post">
            <button class="btn btn-outline-secondary" type="submit">Marcheaza toate ca citite</button>
        </form>
    }
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Nu ai notificari momentan.</div>
}
else
{
    <div class="list-group shadow-sm">
        @foreach (var notification in Model)
        {
            var itemClass = notification.IsRead ? "bg-white" : "list-group-item-warning";
            var badgeClass = notification.Type switch
            {
                AutoAuction.Domain.Enums.NotificationType.Outbid => "text-bg-danger",
                AutoAuction.Domain.Enums.NotificationType.AuctionWon => "text-bg-success",
                AutoAuction.Domain.Enums.NotificationType.AuctionLost => "text-bg-secondary",
                AutoAuction.Domain.Enums.NotificationType.TransactionCreated => "text-bg-info",
                AutoAuction.Domain.Enums.NotificationType.NewBid => "text-bg-primary",
                _ => "text-bg-dark"
            };
            var typeLabel = notification.Type switch
            {
                AutoAuction.Domain.Enums.NotificationType.NewBid => "Bid nou",
                AutoAuction.Domain.Enums.NotificationType.Outbid => "Depasit",
                AutoAuction.Domain.Enums.NotificationType.AuctionWon => "Castigata",
                AutoAuction.Domain.Enums.NotificationType.AuctionLost => "Pierduta",
                AutoAuction.Domain.Enums.NotificationType.AuctionEnded => "Finalizata",
                AutoAuction.Domain.Enums.NotificationType.TransactionCreated => "Tranzactie",
                _ => "Notificare"
            };

            <div class="list-group-item @itemClass">
                <div class="d-flex flex-column flex-md-row justify-content-between gap-2">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <span class="badge @badgeClass">@typeLabel</span>
                            @if (!notification.IsRead)
                            {
                                <span class="badge text-bg-light border">Necitita</span>
                            }
                        </div>
                        <h2 class="h6 mb-1">@notification.Title</h2>
                        <p class="mb-0">@notification.Message</p>
                    </div>
                    <div class="text-md-end flex-shrink-0">
                        <small class="text-muted d-block mb-2">@notification.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                        @if (!notification.IsRead)
                        {
                            <form asp-action="MarkRead" method="post">
                                <input type="hidden" name="id" value="@notification.Id" />
                                <button class="btn btn-sm btn-outline-primary" type="submit">Marcheaza citita</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
