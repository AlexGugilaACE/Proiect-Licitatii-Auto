@model IReadOnlyList<AutoAuction.Domain.Entities.Notification>

@{
    ViewData["Title"] = "Notificări";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Notificări</h1>
    <form asp-action="MarkAllRead" method="post">
        <button class="btn btn-outline-secondary" type="submit">Marchează toate citite</button>
    </form>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Nu ai notificări.</div>
}
else
{
    <div class="list-group">
        @foreach (var notification in Model)
        {
            <div class="list-group-item @(notification.IsRead ? "" : "list-group-item-primary")">
                <div class="d-flex justify-content-between">
                    <strong>@notification.Title</strong>
                    <small>@notification.CreatedAt.ToLocalTime().ToString("g")</small>
                </div>
                <div>@notification.Message</div>
            </div>
        }
    </div>
}
