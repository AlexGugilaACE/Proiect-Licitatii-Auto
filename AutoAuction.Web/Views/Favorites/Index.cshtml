@model IReadOnlyList<AutoAuction.Domain.Entities.Favorite>

@{
    ViewData["Title"] = "Favorite";
}

<h1 class="h3 mb-3">Favorite</h1>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Nu ai licitații salvate la favorite.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Licitație</th>
                <th>Preț curent</th>
                <th>Final</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var favorite in Model)
            {
                <tr>
                    <td>@favorite.Auction?.Title</td>
                    <td>@favorite.Auction?.CurrentPrice.ToString("N2") EUR</td>
                    <td>@favorite.Auction?.EndTime.ToLocalTime().ToString("g")</td>
                    <td><a asp-controller="Auctions" asp-action="Details" asp-route-id="@favorite.AuctionId">Detalii</a></td>
                </tr>
            }
        </tbody>
    </table>
}
