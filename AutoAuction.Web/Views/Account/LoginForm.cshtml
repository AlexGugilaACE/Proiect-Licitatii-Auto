@model AutoAuction.Web.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<section class="auth-form-page">
    <div class="auth-form-card">
        <div class="auth-form-card__header">
            <h1>Login</h1>
            <p>Autentifica-te pentru a continua in platforma.</p>
        </div>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label">Parola</label>
                <input asp-for="Password" class="form-control" />
            </div>
            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label">Tine-ma minte</label>
            </div>
            <button type="submit" class="btn btn-primary w-100">Login</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
