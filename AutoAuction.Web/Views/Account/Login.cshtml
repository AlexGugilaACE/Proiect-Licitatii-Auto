@model AutoAuction.Web.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<h1 class="h3 mb-3">Login</h1>

<form asp-action="Login" method="post" class="col-md-5">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Password" class="form-label">Parolă</label>
        <input asp-for="Password" class="form-control" />
    </div>
    <div class="form-check mb-3">
        <input asp-for="RememberMe" class="form-check-input" />
        <label asp-for="RememberMe" class="form-check-label">Ține-mă minte</label>
    </div>
    <button type="submit" class="btn btn-primary">Login</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
