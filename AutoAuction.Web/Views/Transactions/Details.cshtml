@model AutoAuction.Domain.Entities.Transaction
@using AutoAuction.Domain.Enums

@{
    ViewData["Title"] = "Tranzacție";
}

<h1 class="h3 mb-3">Tranzacție #@Model.Id</h1>

<div class="card">
    <div class="card-body">
        <h2 class="h5">@Model.Auction?.Title</h2>
        <p class="text-muted">@Model.Auction?.Brand?.Name @Model.Auction?.CarModel?.Name</p>
        <dl class="row">
            <dt class="col-sm-3">Sumă</dt>
            <dd class="col-sm-9">@Model.Amount.ToString("N2") EUR</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
            <dt class="col-sm-3">Creată</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("g")</dd>
        </dl>

        @if (Model.Status == TransactionStatus.Pending)
        {
            <div class="d-flex gap-2">
                <form asp-action="Confirm" asp-route-id="@Model.Id" method="post">
                    <button class="btn btn-success" type="submit">Confirmă</button>
                </form>
                <form asp-action="Cancel" asp-route-id="@Model.Id" method="post">
                    <button class="btn btn-outline-danger" type="submit">Anulează</button>
                </form>
            </div>
        }
    </div>
</div>
