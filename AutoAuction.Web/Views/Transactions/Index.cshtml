@model IReadOnlyList<AutoAuction.Domain.Entities.Transaction>

@{
    ViewData["Title"] = "Tranzacții";
}

<h1 class="h3 mb-3">Tranzacții</h1>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Nu există tranzacții pentru contul tău.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Licitație</th>
                <th>Sumă</th>
                <th>Status</th>
                <th>Creată</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var transaction in Model)
            {
                <tr>
                    <td>@transaction.Auction?.Title</td>
                    <td>@transaction.Amount.ToString("N2") EUR</td>
                    <td>@transaction.Status</td>
                    <td>@transaction.CreatedAt.ToLocalTime().ToString("g")</td>
                    <td><a asp-action="Details" asp-route-id="@transaction.Id">Detalii</a></td>
                </tr>
            }
        </tbody>
    </table>
}
