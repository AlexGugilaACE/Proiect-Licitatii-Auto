<!DOCTYPE html>
@using System.Security.Claims
@using AutoAuction.Infrastructure.Identity
@inject AutoAuction.Application.Interfaces.INotificationService NotificationService
@inject Microsoft.AspNetCore.Identity.UserManager<ApplicationUser> UserManager
@{
    var unreadNotifications = 0;
    var currentUserDisplayName = User.Identity?.Name ?? string.Empty;
    if (User.Identity?.IsAuthenticated == true)
    {
        var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (!string.IsNullOrWhiteSpace(userId))
        {
            unreadNotifications = await NotificationService.GetUnreadCountAsync(userId);
        }

        var currentUser = await UserManager.GetUserAsync(User);
        if (currentUser is not null)
        {
            currentUserDisplayName = $"{currentUser.FirstName} {currentUser.LastName}".Trim();
            if (string.IsNullOrWhiteSpace(currentUserDisplayName))
            {
                currentUserDisplayName = currentUser.Email ?? User.Identity.Name ?? string.Empty;
            }
        }
    }
}
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AUTOAUCTION</title>
    <script type="importmap"></script>
    <link rel="icon" type="image/png" sizes="32x32" href="~/images/bid.png" asp-append-version="true" />
    <link rel="shortcut icon" type="image/png" href="~/images/bid.png" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AutoAuction.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid layout-navbar-container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">AUTOAUCTION</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Auctions" asp-action="Index">Licitații</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Vanzator"))
                            {
                                <li class="nav-item navbar-icon-item">
                                    <a class="auction-card__icon-btn navbar-icon-link navbar-icon-link--add" asp-controller="Auctions" asp-action="Create" aria-label="Adaugă licitație" title="Adaugă licitație">
                                        <svg viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M11 5h2v6h6v2h-6v6h-2v-6H5v-2h6V5Z" />
                                        </svg>
                                    </a>
                                </li>
                            }
                            <li class="nav-item navbar-icon-item">
                                <a class="auction-card__icon-btn auction-card__icon-btn--heart navbar-icon-link" asp-controller="Favorites" asp-action="Index" aria-label="Favorite" title="Favorite">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M12 21s-7-4.43-9.4-8.52C.55 8.98 2.9 5 6.63 5c2.02 0 3.34 1.12 4.08 2.06.32.4.9.4 1.21 0C12.66 6.12 13.98 5 16 5c3.73 0 6.08 3.98 4.03 7.48C17.63 16.57 12 21 12 21Z" />
                                    </svg>
                                </a>
                            </li>
                            <li class="nav-item navbar-icon-item">
                                <a class="auction-card__icon-btn navbar-icon-link navbar-icon-link--notification" asp-controller="Notifications" asp-action="Index" aria-label="Notificari" title="Notificari">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M12 22a2.75 2.75 0 0 0 2.58-1.82H9.42A2.75 2.75 0 0 0 12 22Zm7-6.2-1.5-1.92V10a5.52 5.52 0 0 0-4.25-5.36V3a1.25 1.25 0 0 0-2.5 0v1.64A5.52 5.52 0 0 0 6.5 10v3.88L5 15.8V18h14v-2.2Z" />
                                    </svg>
                                    @if (unreadNotifications > 0)
                                    {
                                        <span class="navbar-icon-badge">@unreadNotifications</span>
                                    }
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <button class="btn btn-link nav-link text-dark dropdown-toggle navbar-user-name" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @currentUserDisplayName
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end navbar-user-menu">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="MyAccount">Contul meu</a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Transactions" asp-action="Index">Tranzactii</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Favorites" asp-action="Index">Favorite</a>
                                    </li>

                                    @if (User.IsInRole("Vanzator"))
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Auctions" asp-action="Mine">Licitațiile mele</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Auctions" asp-action="Create">Adaugă licitație</a>
                                        </li>
                                    }

                                    @if (User.IsInRole("Administrator"))
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Index">Admin dashboard</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Users">Utilizatori</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Auctions">Administrare licitații</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="ReferenceData">Dropdown-uri</a>
                                        </li>
                                    }

                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button class="dropdown-item" type="submit">Logout</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Login/Inregistrare</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container page-shell">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer border-top">
        <div class="container">
            <div class="site-footer__links">
                <section>
                    <h2>Informatii</h2>
                    <a href="#">Despre platforma</a>
                    <a href="#">Cum functioneaza</a>
                    <a href="#">Termeni si conditii</a>
                </section>
                <section>
                    <h2>Cumpara vehicule</h2>
                    <a href="#">Licitații active</a>
                    <a href="#">Favorite</a>
                    <a href="#">Ghid cumparator</a>
                </section>
                <section>
                    <h2>Vinde vehicule</h2>
                    <a href="#">Adaugă licitație</a>
                    <a href="#">Licitațiile mele</a>
                    <a href="#">Ghid vânzător</a>
                </section>
                <section>
                    <h2>Help</h2>
                    <a href="#">Contact</a>
                    <a href="#">Întrebări frecvente</a>
                    <a href="#">Suport cont</a>
                </section>
            </div>
            <div class="site-footer__copy">&copy; 2026 - AUTOAUCTION</div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
