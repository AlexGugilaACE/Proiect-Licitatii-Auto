@model AutoAuction.Web.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin";
}

<section class="dashboard-page">
    <div class="dashboard-header">
        <div>
            <h1>Dashboard administrator</h1>
            <p>Privire rapida asupra activitatii din platforma.</p>
        </div>
        <div class="dashboard-actions">
            <a class="btn btn-primary" asp-action="Users">Utilizatori</a>
            <a class="btn btn-outline-primary" asp-action="Auctions">Licitatii</a>
            <a class="btn btn-outline-primary" asp-action="ReferenceData">Dropdown-uri</a>
        </div>
    </div>

    <div class="dashboard-stats dashboard-stats--four">
        <div class="dashboard-stat">
            <span>Utilizatori</span>
            <strong>@Model.UserCount</strong>
        </div>
        <div class="dashboard-stat">
            <span>Licitatii</span>
            <strong>@Model.AuctionCount</strong>
        </div>
        <div class="dashboard-stat">
            <span>Active</span>
            <strong>@Model.ActiveAuctionCount</strong>
        </div>
        <div class="dashboard-stat">
            <span>Total tranzactii</span>
            <strong>@Model.TransactionTotal.ToString("N0") EUR</strong>
        </div>
    </div>

    <div class="dashboard-grid dashboard-grid--admin">
        <section class="dashboard-panel">
            <div class="dashboard-panel__header">
                <h2>Licitatii recente</h2>
                <a asp-action="Auctions">Vezi toate</a>
            </div>

            <div class="dashboard-list">
                @foreach (var auction in Model.RecentAuctions)
                {
                    var mainImage = auction.Images.OrderByDescending(x => x.IsMainImage).ThenBy(x => x.SortOrder).FirstOrDefault();

                    <article class="dashboard-list-item dashboard-list-item--with-thumb clickable-card" data-card-url="@Url.Action("Details", "Auctions", new { id = auction.Id })">
                        <div class="dashboard-thumb">
                            @if (mainImage is not null)
                            {
                                <img src="@mainImage.FilePath" alt="@auction.Title" />
                            }
                            else
                            {
                                <span>@auction.Brand?.Name</span>
                            }
                        </div>
                        <div>
                            <h3>@auction.Title</h3>
                            <p>@auction.Brand?.Name @auction.CarModel?.Name</p>
                        </div>
                        <div class="dashboard-list-item__side">
                            <strong>@auction.CurrentPrice.ToString("N0") EUR</strong>
                            @await Html.PartialAsync("_AuctionStatusBadge", auction.Status)
                            <a asp-controller="Auctions" asp-action="Details" asp-route-id="@auction.Id">Detalii</a>
                        </div>
                    </article>
                }
            </div>
        </section>

        <section class="dashboard-panel">
            <div class="dashboard-panel__header">
                <h2>Utilizatori recenti</h2>
                <a asp-action="Users">Gestioneaza</a>
            </div>

            <div class="dashboard-list">
                @foreach (var user in Model.RecentUsers)
                {
                    <article class="dashboard-list-item dashboard-list-item--compact">
                        <div>
                            <h3>@($"{user.FirstName} {user.LastName}".Trim())</h3>
                            <p>@user.Email</p>
                        </div>
                        <div class="dashboard-list-item__side">
                            <span>@user.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</span>
                        </div>
                    </article>
                }
            </div>
        </section>
    </div>
</section>
