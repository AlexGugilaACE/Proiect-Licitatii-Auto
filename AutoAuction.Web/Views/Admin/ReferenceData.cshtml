@model AutoAuction.Web.Models.ReferenceDataAdminViewModel
@using AutoAuction.Web.Models

@{
    ViewData["Title"] = "Dropdown-uri";
}

<h1 class="h3 mb-3">Dropdown-uri și nomenclatoare</h1>

<div class="row g-4">
    <div class="col-lg-4">
        <h2 class="h5">Mărci</h2>
        <form asp-action="AddBrand" method="post" class="d-flex gap-2 mb-3">
            <input name="Name" class="form-control" placeholder="Marcă nouă" />
            <button class="btn btn-primary" type="submit">Adaugă</button>
        </form>
        <ul class="list-group reference-data-list">
            @foreach (var brand in Model.Brands)
            {
                <li class="list-group-item">@brand.Name</li>
            }
        </ul>
    </div>

    <div class="col-lg-4">
        <h2 class="h5">Modele</h2>
        <form asp-action="AddModel" method="post" class="mb-3">
            <select name="BrandId" asp-items="Model.BrandItems" class="form-select mb-2"></select>
            <div class="d-flex gap-2">
                <input name="Name" class="form-control" placeholder="Model nou" />
                <button class="btn btn-primary" type="submit">Adaugă</button>
            </div>
        </form>
        <ul class="list-group reference-data-list">
            @foreach (var carModel in Model.Models)
            {
                <li class="list-group-item">@carModel.Brand?.Name @carModel.Name</li>
            }
        </ul>
    </div>

    <div class="col-lg-4">
        <h2 class="h5">Caracteristici</h2>
        <form asp-action="AddAttributeOption" method="post" class="mb-3">
            <select name="Type" asp-items="Model.AttributeTypes" class="form-select mb-2"></select>
            <div class="d-flex gap-2">
                <input name="Name" class="form-control" placeholder="Opțiune nouă" />
                <button class="btn btn-primary" type="submit">Adaugă</button>
            </div>
        </form>
        <div class="reference-data-table">
        <table class="table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th>Tip</th>
                    <th>Nume</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var option in Model.Options)
                {
                    <tr class="@(option.IsActive ? "" : "table-secondary")">
                        <td>@option.Type</td>
                        <td>@option.Name</td>
                        <td>
                            <form asp-action="ToggleAttributeOption" asp-route-id="@option.Id" method="post">
                                <button class="btn btn-sm btn-outline-secondary" type="submit">@(option.IsActive ? "Dezactivează" : "Activează")</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
</div>
