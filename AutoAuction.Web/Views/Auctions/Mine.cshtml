@model IReadOnlyList<AutoAuction.Domain.Entities.Auction>

@{
    ViewData["Title"] = "Licitatiile mele";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Licitatiile mele</h1>
    <a class="btn btn-primary" asp-action="Create">Adaugă licitație</a>
</div>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Titlu</th>
            <th>Status</th>
            <th>Preț curent</th>
            <th>Final</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var auction in Model)
        {
            <tr>
                <td>@auction.Title</td>
                <td>@auction.Status</td>
                <td>@auction.CurrentPrice.ToString("N2") EUR</td>
                <td>@auction.EndTime.ToLocalTime().ToString("g")</td>
                <td class="d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@auction.Id">Detalii</a>
                    <a asp-action="Edit" asp-route-id="@auction.Id">Editează</a>
                </td>
            </tr>
        }
    </tbody>
</table>
