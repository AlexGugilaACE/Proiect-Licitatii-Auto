@model IReadOnlyList<AutoAuction.Domain.Entities.Auction>
@using AutoAuction.Domain.Enums

@{
    ViewData["Title"] = "Licitatiile mele";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Licitatiile mele</h1>
        <div class="text-muted">Anunturile publicate de tine in platforma.</div>
    </div>
    <a class="btn btn-primary" asp-action="Create">Adaugă licitație</a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Nu ai publicat încă nicio licitație.</div>
}
else
{
    <div class="favorite-list">
        @foreach (var auction in Model)
        {
            var mainImage = auction.Images.OrderByDescending(x => x.IsMainImage).ThenBy(x => x.SortOrder).FirstOrDefault();
            var priceText = auction.CurrentPrice.ToString("N0");
            <article class="favorite-auction seller-auction clickable-card" data-card-url="@Url.Action("Details", "Auctions", new { id = auction.Id })">
                <div class="favorite-auction__media">
                    @if (mainImage is not null)
                    {
                        <img src="@mainImage.FilePath" alt="@auction.Title" />
                    }
                    else
                    {
                        <div class="favorite-auction__placeholder">@auction.Brand?.Name @auction.CarModel?.Name</div>
                    }
                </div>

                <div class="favorite-auction__content">
                    <div class="favorite-auction__main">
                        <div>
                            <div class="admin-auction__heading">
                                <h2 class="favorite-auction__title">@auction.Title</h2>
                                @await Html.PartialAsync("_AuctionStatusBadge", auction.Status)
                            </div>
                            <div class="favorite-auction__meta">
                                @auction.Brand?.Name @auction.CarModel?.Name · publicata pe @auction.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </div>
                        </div>

                        <div class="favorite-auction__specs">
                            <div class="favorite-auction__spec">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M12 5a9 9 0 0 0-9 9c0 1.66.45 3.22 1.24 4.56h15.52A8.96 8.96 0 0 0 12 5Zm0 2a7 7 0 0 1 6.32 10H5.68A7 7 0 0 1 12 7Zm4.32 3.2-3.34 4.84a1.75 1.75 0 1 1-1.6-1.03l3.34-4.84 1.6 1.03Z" />
                                </svg>
                                <span>@auction.Mileage.ToString("N0") km</span>
                            </div>
                            <div class="favorite-auction__spec">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M7 3h8a3 3 0 0 1 3 3v15h-2v-5H6v5H4V6a3 3 0 0 1 3-3Zm-1 8h10V6a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1v5Zm2 2a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Zm7.5 0A1.5 1.5 0 1 0 17 14.5 1.5 1.5 0 0 0 15.5 13ZM18 8h2.5a1.5 1.5 0 0 1 1.5 1.5V13h-2V10h-2V8Z" />
                                </svg>
                                <span>@auction.FuelType?.Name</span>
                            </div>
                            <div class="favorite-auction__spec">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M7 4a2 2 0 1 1-1 3.73V11h5V7.73a2 2 0 1 1 2 0V11h4V7.73a2 2 0 1 1 2 0V13h-6v3.27a2 2 0 1 1-2 0V13H6v3.27a2 2 0 1 1-2 0V7.73A2 2 0 0 1 7 4Z" />
                                </svg>
                                <span>@auction.TransmissionType?.Name</span>
                            </div>
                            <div class="favorite-auction__spec">
                                <span class="favorite-auction__dot"></span>
                                <span>Final: @auction.EndTime.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                            </div>
                        </div>
                    </div>

                    <div class="favorite-auction__side">
                        <div class="favorite-auction__price">@priceText EUR</div>
                        <div class="favorite-auction__actions">
                            <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-route-id="@auction.Id">Editeaza</a>
                        </div>
                        <a class="favorite-auction__details" asp-action="Details" asp-route-id="@auction.Id">
                            Vezi detalii
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M13.3 5.3 20 12l-6.7 6.7-1.4-1.4 4.3-4.3H4v-2h12.2l-4.3-4.3 1.4-1.4Z" />
                            </svg>
                        </a>
                    </div>
                </div>
            </article>
        }
    </div>
}
