@model AutoAuction.Web.Models.SellerDashboardViewModel

@{
    ViewData["Title"] = "Dashboard vanzator";
}

<section class="dashboard-page">
    <div class="dashboard-header">
        <div>
            <h1>Dashboard vanzator</h1>
            <p>Urmareste licitatiile publicate si tranzactiile generate.</p>
        </div>
        <div class="dashboard-actions">
            <a class="btn btn-primary" asp-controller="Auctions" asp-action="Create">Adauga licitatie</a>
            <a class="btn btn-outline-primary" asp-controller="Auctions" asp-action="Mine">Licitatiile mele</a>
        </div>
    </div>

    <div class="dashboard-stats dashboard-stats--four">
        <div class="dashboard-stat">
            <span>Licitatii</span>
            <strong>@Model.AuctionCount</strong>
        </div>
        <div class="dashboard-stat">
            <span>Active</span>
            <strong>@Model.ActiveAuctionCount</strong>
        </div>
        <div class="dashboard-stat">
            <span>Finalizate</span>
            <strong>@Model.EndedAuctionCount</strong>
        </div>
        <div class="dashboard-stat">
            <span>Tranzactii</span>
            <strong>@Model.TransactionCount</strong>
        </div>
    </div>

    <div class="dashboard-grid">
        <section class="dashboard-panel">
            <div class="dashboard-panel__header">
                <h2>Licitatii recente</h2>
                <a asp-controller="Auctions" asp-action="Mine">Vezi toate</a>
            </div>

            <div class="dashboard-list">
                @foreach (var auction in Model.RecentAuctions)
                {
                    var mainImage = auction.Images.OrderByDescending(x => x.IsMainImage).ThenBy(x => x.SortOrder).FirstOrDefault();

                    <article class="dashboard-list-item dashboard-list-item--with-thumb clickable-card" data-card-url="@Url.Action("Details", "Auctions", new { id = auction.Id })">
                        <div class="dashboard-thumb">
                            @if (mainImage is not null)
                            {
                                <img src="@mainImage.FilePath" alt="@auction.Title" />
                            }
                            else
                            {
                                <span>@auction.Brand?.Name</span>
                            }
                        </div>
                        <div>
                            <h3>@auction.Title</h3>
                            <p>@auction.Brand?.Name @auction.CarModel?.Name</p>
                        </div>
                        <div class="dashboard-list-item__side">
                            <strong>@auction.CurrentPrice.ToString("N0") EUR</strong>
                            @await Html.PartialAsync("_AuctionStatusBadge", auction.Status)
                            <a asp-controller="Auctions" asp-action="Details" asp-route-id="@auction.Id">Detalii</a>
                        </div>
                    </article>
                }
            </div>
        </section>

        <section class="dashboard-panel">
            <div class="dashboard-panel__header">
                <h2>Tranzactii recente</h2>
                <a asp-controller="Transactions" asp-action="Index">Vezi toate</a>
            </div>

            <div class="dashboard-list">
                @foreach (var transaction in Model.RecentTransactions)
                {
                    var mainImage = transaction.Auction?.Images.OrderByDescending(x => x.IsMainImage).ThenBy(x => x.SortOrder).FirstOrDefault();

                    <article class="dashboard-list-item dashboard-list-item--with-thumb clickable-card" data-card-url="@Url.Action("Details", "Transactions", new { id = transaction.Id })">
                        <div class="dashboard-thumb">
                            @if (mainImage is not null)
                            {
                                <img src="@mainImage.FilePath" alt="@transaction.Auction?.Title" />
                            }
                            else
                            {
                                <span>@transaction.Auction?.Brand?.Name</span>
                            }
                        </div>
                        <div>
                            <h3>@transaction.Auction?.Title</h3>
                            <p>Status: @transaction.Status</p>
                        </div>
                        <div class="dashboard-list-item__side">
                            <strong>@transaction.Amount.ToString("N0") EUR</strong>
                            <a asp-controller="Transactions" asp-action="Details" asp-route-id="@transaction.Id">Detalii</a>
                        </div>
                    </article>
                }
            </div>
        </section>
    </div>
</section>
